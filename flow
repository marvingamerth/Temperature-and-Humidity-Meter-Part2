        "type": "function",
        "z": "83433bbfc4f221ea",
        "name": "Calc Consumed from Level",
        "func": "let currentLevel = parseFloat(msg.payload);\nif (isNaN(currentLevel)) return null;\n\nlet lastLevel = flow.get('lastWaterLevel');\nlet glassCapacity = 400; // ความจุแก้วน้ำ (ml) เปลี่ยนค่าได้ที่นี่\nlet consumedAmount = 0;\n\nif (lastLevel !== undefined && currentLevel < lastLevel) {\n    // ถ้าระดับน้ำลดลง ให้คำนวณปริมาณที่ดื่ม\n    // สมมติว่าเซ็นเซอร์ส่งมาเป็น % (0-100)\n    let diffPercent = lastLevel - currentLevel;\n    consumedAmount = (diffPercent / 100) * glassCapacity;\n    \n    // *หมายเหตุ: ถ้าเซ็นเซอร์คุณส่งมาเป็น ml ตรงๆ เลย ให้ใช้บรรทัดล่างนี้แทน*\n    // consumedAmount = lastLevel - currentLevel;\n}\n\n// บันทึกระดับน้ำปัจจุบันไว้เทียบในครั้งถัดไป\nflow.set('lastWaterLevel', currentLevel);\n\nif (consumedAmount > 0) {\n    msg.payload = consumedAmount;\n    return msg;\n}\nreturn null;",
